<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cactus Lab | Extrait de Parfum</title>
    <style>
        /* LUXURY FONT IMPORTS */
        @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500&family=Jost:wght@300;400;500&family=Great+Vibe&display=swap');
        
        body { margin: 0; font-family: 'Jost', sans-serif; background-color: #050505; color: #e0e0e0; -webkit-font-smoothing: antialiased; overflow-x: hidden; letter-spacing: 0.5px; }
        h1, h2, h3, h4 { font-family: 'Cinzel', serif; text-transform: uppercase; letter-spacing: 4px; font-weight: 400; margin: 0; }
        
        /* REFINED MARQUEE */
        .marquee { background: #080808; color: #C4A661; border-bottom: 1px solid #1a1a1a; padding: 10px 0; overflow: hidden; white-space: nowrap; font-size: 0.65rem; letter-spacing: 3px; font-weight: 400; text-transform: uppercase; width: 100%; position: absolute; top: 0; z-index: 1000; }
        .marquee span { display: inline-block; animation: marquee 25s linear infinite; }
        .marquee span::after { content: " • FREE TESTER WITH EVERY 50ML • EXTRAIT DE PARFUM • CRAFTED IN LAB • COMPLIMENTARY SHIPPING • "; padding-left: 10px; }
        @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
        
        /* MINIMALIST HEADER */
        .header { position: sticky; top: 0; background: rgba(5, 5, 5, 0.98); backdrop-filter: blur(15px); display: flex; justify-content: space-between; align-items: center; padding: 20px 25px; z-index: 999; border-bottom: 1px solid #111; margin-top: 35px; }
        .header-icons { display: flex; gap: 20px; font-size: 1.1rem; cursor: pointer; color: #fff; font-weight: 300; }
        .header-logo { font-family: 'Great Vibe', cursive; font-size: 2.8rem; color: #C4A661; text-shadow: 1px 1px 10px rgba(0,0,0,0.5); }
        .cart-icon { position: relative; }
        .cart-badge { position: absolute; top: -6px; right: -8px; background: #C4A661; color: #000; font-size: 0.55rem; font-weight: 500; border-radius: 50%; padding: 2px 5px; font-family: 'Jost'; }

        /* MOODY HERO SECTION */
        .hero { height: 85vh; background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1588405748880-12d1d2a59f75?q=80&w=2000&auto=format&fit=crop') center/cover; display: flex; align-items: flex-end; justify-content: center; text-align: center; padding-bottom: 80px; }
        .hero-text h1 { font-size: 2.5rem; color: #fff; letter-spacing: 6px; margin-bottom: 10px; }
        .hero-text p { font-size: 0.75rem; letter-spacing: 5px; color: #C4A661; margin-top: 15px; font-family: 'Jost'; }
        
        .section { padding: 80px 20px; max-width: 1200px; margin: auto; text-align: center; border-bottom: 1px solid #111; }
        
        /* EDITORIAL COLLECTION GRID */
        .collection-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 40px; }
        .collection-card { position: relative; cursor: pointer; overflow: hidden; background: #000; }
        .collection-card img { width: 100%; height: 220px; object-fit: cover; filter: grayscale(30%) brightness(0.6); display: block; transition: 0.8s ease; }
        .collection-card:hover img { filter: grayscale(0%) brightness(0.9); transform: scale(1.05); }
        .collection-card h3 { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: white; font-size: 1rem; letter-spacing: 3px; }
        
        /* LUXURY PRODUCT GRID (2-in-row) */
        .product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 40px; }
        .product-card { background: #080808; text-align: center; cursor: pointer; padding-bottom: 25px; border: 1px solid #111; transition: 0.4s ease; }
        .product-card:hover { border-color: #333; }
        .product-card img { width: 100%; aspect-ratio: 4/5; object-fit: cover; filter: brightness(0.85); }
        .product-card-info { padding: 25px 15px; }
        .product-card-info h3 { font-size: 0.9rem; color: #fff; letter-spacing: 2px; margin-bottom: 10px; }
        .product-card-info p { font-size: 0.75rem; color: #777; margin: 0 0 15px 0; line-height: 1.6; }
        .price { color: #C4A661; font-weight: 400; font-size: 0.85rem; letter-spacing: 1px; }
        
        /* DELICATE BUTTONS */
        .btn { background: transparent; color: #C4A661; border: 1px solid #C4A661; padding: 14px; cursor: pointer; font-family: 'Jost', sans-serif; text-transform: uppercase; font-size: 0.65rem; letter-spacing: 3px; width: 100%; margin-top: 15px; transition: 0.4s ease; }
        .btn:hover { background: #C4A661; color: #000; }
        .btn-solid { background: #C4A661; color: #000; font-weight: 500; border: none; }
        
        /* SIDE CART */
        .cart-drawer { position: fixed; top: 0; right: -100%; width: 90%; max-width: 400px; height: 100vh; background: #050505; z-index: 10000; transition: 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94); border-left: 1px solid #1a1a1a; display: flex; flex-direction: column; }
        .cart-drawer.open { right: 0; }
        .cart-header { padding: 30px 20px; border-bottom: 1px solid #111; display: flex; justify-content: space-between; align-items: center; }
        .cart-header h2 { font-size: 1.2rem; color: #C4A661; }
        .cart-close { font-size: 2.5rem; cursor: pointer; color: #555; line-height: 1; font-family: 'Jost'; font-weight: 200; transition: 0.3s; }
        .cart-close:hover { color: #fff; }
        .cart-items { flex: 1; overflow-y: auto; padding: 20px; }
        .cart-item { display: flex; gap: 15px; margin-bottom: 25px; border-bottom: 1px solid #111; padding-bottom: 20px; }
        .cart-item img { width: 70px; height: 90px; object-fit: cover; border: 1px solid #222;}
        .cart-item-details { flex: 1; text-align: left;}
        .cart-item-title { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; font-family: 'Cinzel'; margin-bottom: 5px; }
        .cart-item-price { color: #C4A661; font-size: 0.8rem; }
        .qty-controls { display: flex; align-items: center; gap: 15px; margin-top: 12px; border: 1px solid #222; width: fit-content; padding: 4px 12px; font-size: 0.8rem; }
        .qty-btn { background: none; border: none; color: #aaa; cursor: pointer; font-size: 1rem; padding: 0 5px; font-family: 'Jost'; }
        .cart-footer { padding: 30px 20px; border-top: 1px solid #111; background: #080808; }
        .cart-total { display: flex; justify-content: space-between; margin-bottom: 20px; font-size: 1rem; letter-spacing: 2px; text-transform: uppercase;}
        
        /* WINDOW OVERLAYS */
        .overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #050505; z-index: 9999; overflow-y: auto; color: #fafafa; }
        .overlay-content { padding: 30px 15px 60px; max-width: 1000px; margin: auto; }
        
        /* HIGH-END FOOTER */
        .footer { background: #050505; padding: 60px 20px 30px; text-align: left; font-size: 0.75rem; line-height: 2; color: #777; letter-spacing: 0.5px; }
        .footer-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
        .footer h3 { color: #C4A661; font-size: 0.9rem; margin-bottom: 20px; letter-spacing: 3px; font-family: 'Cinzel'; }
        .footer a { color: #777; text-decoration: none; display: block; transition: 0.3s; }
        .footer a:hover { color: #fff; }
        .footer-bottom { text-align: center; padding-top: 30px; margin-top: 40px; border-top: 1px solid #111; font-size: 0.65rem; letter-spacing: 2px; text-transform: uppercase; }
    </style>
</head>
<body>
    <div class="marquee">
        <span>FREE TESTER WITH EVERY 50ML • EXTRAIT DE PARFUM • CRAFTED IN LAB • COMPLIMENTARY SHIPPING</span>
    </div>

    <header class="header">
        <div class="header-icons">☰</div>
        <div class="header-logo">Cactus Lab</div>
        <div class="header-icons">
            <span onclick="alert('Search feature coming soon!')">🔍</span>
            <div class="cart-icon" onclick="toggleCart()">🛒<span class="cart-badge" id="cartBadge">0</span></div>
        </div>
    </header>

    <div class="hero">
        <div class="hero-text">
            <h1>The Dark Collection</h1>
            <p>Shop The Essence</p>
        </div>
    </div>

    <div class="section">
        <h2 style="color: #C4A661;">Our Curations</h2>
        <p style="color: #666; font-size: 0.8rem; margin-top: 15px; letter-spacing: 1px;">Discover our artisanal extrait formulations.</p>
        <div class="collection-grid">
            <div class="collection-card" onclick="openCategory('Summer')">
                <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=400&auto=format&fit=crop" alt="Summer">
                <h3>Summer</h3>
            </div>
            <div class="collection-card" onclick="openCategory('Winter')">
                <img src="https://images.unsplash.com/photo-1445384763658-0400939829cd?q=80&w=400&auto=format&fit=crop" alt="Winter">
                <h3>Winter</h3>
            </div>
            <div class="collection-card" onclick="openCategory('Gourmand')">
                <img src="https://images.unsplash.com/photo-1511920170033-f8396924c348?q=80&w=400&auto=format&fit=crop" alt="Gourmand">
                <h3>Gourmand</h3>
            </div>
        </div>
    </div>

    <div class="overlay" id="categoryModal">
        <div class="header" style="margin-top:0; position:relative; border:none; padding: 15px;">
            <span style="font-size: 2rem; cursor:pointer; font-weight: 200;" onclick="closeOverlay('categoryModal')">←</span>
            <h2 id="categoryTitle" style="color: #C4A661; font-size: 1.5rem;">Collection</h2>
            <div class="cart-icon" onclick="toggleCart()">🛒</div>
        </div>
        <div class="overlay-content">
            <div class="product-grid" id="categoryGrid"></div>
        </div>
    </div>

    <div class="cart-drawer" id="cartDrawer">
        <div class="cart-header">
            <h2>Your Cart</h2>
            <span class="cart-close" onclick="toggleCart()">&times;</span>
        </div>
        <div class="cart-items" id="cartItemsContainer">
            <p style="text-align:center; color:#555; margin-top:50px; font-style: italic;">Your cart is beautifully empty.</p>
        </div>
        <div class="cart-footer">
            <div class="cart-total">
                <span style="font-family: 'Cinzel';">Total</span>
                <span style="color:#C4A661; font-family: 'Jost'; font-weight: 400;" id="cartTotalDisplay">₹0</span>
            </div>
            <button class="btn btn-solid" onclick="checkout()">Checkout via WhatsApp</button>
        </div>
    </div>

    <div id="cartOverlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:9998; backdrop-filter: blur(5px);" onclick="toggleCart()"></div>

    <footer class="footer">
        <div class="footer-grid">
            <div>
                <h3>At Cactus Lab</h3>
                <a href="#">Our Story</a>
                <a href="#">The Lab Values</a>
                <a href="#">Ingredients & Sourcing</a>
            </div>
            <div>
                <h3>Client Care</h3>
                <a href="#">Contact Us</a>
                <a href="#">Shipping & Returns</a>
                <a href="#">Track Order</a>
                <a href="#">FAQs</a>
            </div>
        </div>
        <div style="margin-top: 40px;">
            <h3 style="margin-bottom: 10px;">Contact</h3>
            <p>Email: support@cactuslab.com<br>Phone: +91 88194 996XX<br>Mumbai, India</p>
        </div>
        <div class="footer-bottom">
            &copy; 2026 CACTUS LAB PERFUMES. ALL RIGHTS RESERVED.
        </div>
    </footer>
        <script>
        const perfumes = {
            Summer: [
                { id: 's1', name: 'Oceania', price: 1900, desc: 'Sea Spray, Bergamot, Water Lily.', img: 'https://images.unsplash.com/photo-1592945403244-b3fbafd7f539?q=80&w=600&auto=format&fit=crop' },
                { id: 's2', name: 'Bleu de Chanel', price: 2100, desc: 'Lemon Zest, Ginger, Cedarwood.', img: 'https://images.unsplash.com/photo-1523293115678-d2900f505161?q=80&w=600&auto=format&fit=crop' },
                { id: 's3', name: 'Summer Hammer', price: 1900, desc: 'Coconut Water, Mango, Woods.', img: 'https://images.unsplash.com/photo-1595425970377-c9703c48657a?q=80&w=600&auto=format&fit=crop' }
            ],
            Winter: [
                { id: 'w1', name: 'Most Wanted', price: 2400, desc: 'Cardamom, Black Amber, Leather.', img: 'https://images.unsplash.com/photo-1588405748880-12d1d2a59f75?q=80&w=600&auto=format&fit=crop' },
                { id: 'w2', name: 'Althair', price: 2200, desc: 'Mountain Air, Juniper, Vanilla.', img: 'https://images.unsplash.com/photo-1616949755610-8c9bbc08f138?q=80&w=600&auto=format&fit=crop' },
                { id: 'w3', name: 'Reserve Prive', price: 2600, desc: 'Aged Scotch, Smoke, Patchouli.', img: 'https://images.unsplash.com/photo-1594035910387-fea47794261f?q=80&w=600&auto=format&fit=crop' }
            ],
            Gourmand: [
                { id: 'g1', name: 'Amore Cafe', price: 1900, desc: 'Roasted Coffee, Biscotti, Vanilla.', img: 'https://images.unsplash.com/photo-1615634260167-c8cdede054de?q=80&w=600&auto=format&fit=crop' },
                { id: 'g2', name: 'Arabians Tonka', price: 2500, desc: 'Saffron, Dates, Tonka Bean, Oud.', img: 'https://images.unsplash.com/photo-1547887538-e3a2f32cb1cc?q=80&w=600&auto=format&fit=crop' }
            ]
        };

        let cart = {};

        function openCategory(category) {
            document.getElementById('categoryTitle').innerText = category;
            let grid = document.getElementById('categoryGrid');
            grid.innerHTML = ''; 

            perfumes[category].forEach(p => {
                grid.innerHTML += `
                    <div class="product-card">
                        <img src="${p.img}" alt="${p.name}">
                        <div class="product-card-info">
                            <h3>${p.name}</h3>
                            <p>${p.desc}</p>
                            <div class="price">₹${p.price}</div>
                            <button class="btn" onclick="addToCart('${p.name}', ${p.price}, '${p.img}')">Add to Cart</button>
                        </div>
                    </div>
                `;
            });

            document.getElementById('categoryModal').style.display = 'block';
            window.scrollTo(0,0);
        }

        function closeOverlay(id) {
            document.getElementById(id).style.display = 'none';
        }

        function toggleCart() {
            const drawer = document.getElementById('cartDrawer');
            const overlay = document.getElementById('cartOverlay');
            if (drawer.classList.contains('open')) {
                drawer.classList.remove('open');
                overlay.style.display = 'none';
            } else {
                drawer.classList.add('open');
                overlay.style.display = 'block';
                renderCart();
            }
        }

        function addToCart(name, price, img) {
            if (cart[name]) {
                cart[name].qty += 1;
            } else {
                cart[name] = { price: price, qty: 1, img: img };
            }
            updateBadge();
            toggleCart(); 
        }

        function updateQty(name, change) {
            if (cart[name]) {
                cart[name].qty += change;
                if (cart[name].qty <= 0) {
                    delete cart[name];
                }
                updateBadge();
                renderCart();
            }
        }

        function updateBadge() {
            let totalItems = 0;
            for (let item in cart) { totalItems += cart[item].qty; }
            document.getElementById('cartBadge').innerText = totalItems;
        }

        function renderCart() {
            let container = document.getElementById('cartItemsContainer');
            let total = 0;
            container.innerHTML = '';

            if (Object.keys(cart).length === 0) {
                container.innerHTML = '<p style="text-align:center; color:#555; margin-top:50px; font-style: italic;">Your cart is beautifully empty.</p>';
                document.getElementById('cartTotalDisplay').innerText = "₹0";
                return;
            }

            for (let name in cart) {
                let item = cart[name];
                let itemTotal = item.price * item.qty;
                total += itemTotal;

                container.innerHTML += `
                    <div class="cart-item">
                        <img src="${item.img}" alt="${name}">
                        <div class="cart-item-details">
                            <div class="cart-item-title">${name}</div>
                            <div class="cart-item-price">₹${item.price}</div>
                            <div class="qty-controls">
                                <button class="qty-btn" onclick="updateQty('${name}', -1)">-</button>
                                <span>${item.qty}</span>
                                <button class="qty-btn" onclick="updateQty('${name}', 1)">+</button>
                            </div>
                        </div>
                    </div>
                `;
            }
            document.getElementById('cartTotalDisplay').innerText = "₹" + total;
        }

        function checkout() {
            if (Object.keys(cart).length === 0) {
                alert("Your cart is empty!");
                return;
            }
            
            let phoneNumber = "9188194996"; 
            let message = "Cactus Lab Order:\\n\\n";
            let total = 0;
            
            for (let name in cart) {
                let item = cart[name];
                message += `${item.qty}x ${name} (₹${item.price * item.qty})\\n`;
                total += (item.price * item.qty);
            }
            
            message += `\\nTotal Estimate: ₹${total}\\n\\nPlease confirm my order.`;
            
            let encodedMessage = encodeURIComponent(message);
            window.open("https://wa.me/" + phoneNumber + "?text=" + encodedMessage, '_blank');
        }
    </script>
</body>
</html>
